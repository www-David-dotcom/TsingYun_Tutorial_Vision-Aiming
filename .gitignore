# Godot exports + import cache (Godot 4 generates `.godot/` per
# project on first open; never commit). `.uid` files DO get
# committed — they pin script IDs across editors per Godot 4.4+ docs.
shared/godot_arena/.godot/
shared/godot_arena/.import/
shared/godot_arena/builds/
shared/godot_arena/*.x86_64
shared/godot_arena/*.exe
shared/godot_arena/*.app

# Docker / CI scratch
*.log
.coverage
htmlcov/

# macOS metadata files (the dot-underscore noise that already plagues this checkout)
._*
